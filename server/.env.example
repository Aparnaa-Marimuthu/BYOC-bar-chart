PORT=8787
NODE_ENV=development
BYOC_BACKEND_DEBUG=true
BYOC_USE_MOCK_BACKEND=true
BYOC_CACHE_ENABLED=true
BYOC_CACHE_PROVIDER=memory
BYOC_CACHE_TTL_SECONDS=300
BYOC_CACHE_MAX_ITEMS=500
BYOC_REQUEST_TIMEOUT_MS=60000
BYOC_ALLOWED_ORIGINS=http://localhost:5173,https://*.vercel.app
BYOC_ALLOWED_DIMENSIONS=product_category,product_name,region,channel,location_name,base
BYOC_ALLOWED_METRICS=revenue,units_sold,order_count,first_ninety_day_attrition_rate,average_turn_time,average_turnaround_time_min
BYOC_RATE_LIMIT_ENABLED=false
BYOC_RATE_LIMIT_MAX=120
BYOC_RATE_LIMIT_WINDOW_MS=60000
DATABRICKS_HOST=
DATABRICKS_TOKEN=
DATABRICKS_WAREHOUSE_ID=
DATABRICKS_CATALOG=
DATABRICKS_SCHEMA=
DATABRICKS_TABLE=
DATABRICKS_WAIT_TIMEOUT=50s
DATABRICKS_POLL_INTERVAL_MS=1000
DATABRICKS_MAX_WAIT_MS=60000
ARROW_DOWNLOAD_CONCURRENCY=4
BACKEND_AUTH_MODE=dev
BACKEND_DEV_API_KEY=
